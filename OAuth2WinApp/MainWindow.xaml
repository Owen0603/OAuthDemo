<Window x:Class="OAuth2WinApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OAuth 2.0 登录 Demo (Windows)" Height="420" Width="460"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="40">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- 图标 -->
            <TextBlock Text="🔐" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,16"/>

            <!-- 标题 -->
            <TextBlock x:Name="TitleText" Text="OAuth 2.0 登录 Demo" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <!-- 未登录状态 -->
            <StackPanel x:Name="LoginPanel" HorizontalAlignment="Center">
                <TextBlock Text="点击下方按钮，将在浏览器中完成 OAuth 授权登录"
                           Foreground="Gray" TextWrapping="Wrap" TextAlignment="Center"
                           Margin="0,0,0,20" MaxWidth="320"/>

                <Button x:Name="LoginButton" Content="使用浏览器登录" Click="LoginButton_Click"
                        FontSize="15" Padding="24,10" HorizontalAlignment="Center"
                        Background="#667eea" Foreground="White" BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock x:Name="LoadingText" Text="正在处理回调..." Visibility="Collapsed"
                           HorizontalAlignment="Center" Foreground="Gray" Margin="0,12,0,0"/>

                <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="12"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Visibility="Collapsed" Margin="0,12,0,0" MaxWidth="320"/>
            </StackPanel>

            <!-- 已登录状态 -->
            <StackPanel x:Name="LoggedInPanel" Visibility="Collapsed" HorizontalAlignment="Center">
                <TextBlock Text="✅ 登录成功!" FontSize="20" FontWeight="Bold"
                           Foreground="Green" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                <Border Background="#E8F5E9" CornerRadius="10" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="用户名:" FontWeight="Medium" Grid.Column="0"/>
                            <TextBlock x:Name="UsernameText" Foreground="Gray" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="邮箱:" FontWeight="Medium" Grid.Column="0"/>
                            <TextBlock x:Name="EmailText" Foreground="Gray" Grid.Column="1"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Access Token:" FontWeight="Medium" Grid.Column="0"/>
                            <TextBlock x:Name="TokenText" Foreground="Gray" Grid.Column="1"
                                       TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button x:Name="LogoutButton" Content="退出登录" Click="LogoutButton_Click"
                        FontSize="14" Padding="20,8" HorizontalAlignment="Center"
                        Background="#E53935" Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
