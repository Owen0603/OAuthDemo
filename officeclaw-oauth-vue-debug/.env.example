# 保留主项目 API 代理（可不用）
VITE_API_TARGET=http://127.0.0.1:3004

# Vue 页面调用的流程后端（本 demo 自带）
VITE_DEMO_FLOW_API_TARGET=http://127.0.0.1:3008

# Flow 后端参数（默认值与当前项目常量一致）
DEMO_FLOW_PORT=3008
OAUTH_AUTH_BASE=https://auth.huaweicloud.com
OAUTH_IAM_BASE_URL=https://sts-open.cn-north-7.myhuaweicloud.com
HUAWEI_CLAW_URL=https://versatile.cn-north-4.myhuaweicloud.com
OAUTH_CLIENT_ID=client-officeclaw
# 默认回调到本地捕获页，便于复制到 Step3
OAUTH_REDIRECT_URI=http://127.0.0.1:3008/demo-callback
